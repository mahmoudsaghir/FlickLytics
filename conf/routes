# Routes
# This file defines all application routes (Higher priority routes first)
# ~~~~

# An example controller showing a sample home page
GET         /                                                  controllers.HomeController.redirectToFlicklytics
GET         /flicklytics                                       controllers.HomeController.index(request: Request)
+ nocsrf
POST        /flicklytics                                       controllers.HomeController.search(request: Request)
GET         /flicklytics/global-diversity/:category/:id        controllers.HomeController.globalDiversity(request: Request, category: String, id: Int)

# Map static resources from the /public folder to the /assets URL path
GET         /flicklytics/assets/*file        controllers.Assets.versioned(path="/public", file: Asset)

# Map details for checking items under /flicklytics
GET   /flicklytics/movie/:id   controllers.DetailsController.movie(id: Long, request: Request)
GET   /flicklytics/tv/:id      controllers.DetailsController.tv(id: Long, request: Request)
